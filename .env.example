APP_NAME="Ultimate POS"
APP_TITLE=""
APP_ENV=local
APP_KEY=base64:W8UqtE9LHZW+gRag78o4BCbN1M0w4HdaIFdLqHJ/9PA=
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_URL=http://localhost
APP_LOCALE=en
APP_TIMEZONE="Asia/Kolkata"

ADMINISTRATOR_USERNAMES=
ALLOW_REGISTRATION=true

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
# --- Shared hosting (cPanel): Gmail SMTP is usually BLOCKED (connection timeout). ---
# Option A — Hosting email (recommended on cPanel):
#   MAIL_HOST=mail.yourdomain.com
#   MAIL_PORT=587
#   MAIL_ENCRYPTION=tls
#   MAIL_USERNAME=noreply@yourdomain.com
#   MAIL_PASSWORD=your-cpanel-email-password
#
# Option B — Local relay (many cPanel servers):
#   MAIL_HOST=localhost
#   MAIL_PORT=25
#   MAIL_ENCRYPTION=null
#   MAIL_USERNAME=
#   MAIL_PASSWORD=
#
# Option C — Sendmail (no external SMTP):
#   MAIL_DRIVER=sendmail
#
# Option D — Mailgun HTTP API (works when SMTP ports are blocked):
#   MAIL_DRIVER=mailgun
#   MAILGUN_DOMAIN=mg.yourdomain.com
#   MAILGUN_SECRET=key-xxxxxxxx
#
# Test on server: php artisan mail:test-connection
# Send test:      php artisan mail:test-connection --send
#
# Gmail (only if host allows outbound SMTP + App Password):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_ENCRYPTION=tls
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=60
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun (when MAIL_DRIVER=mailgun)
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

ENVATO_PURCHASE_CODE=
MAC_LICENCE_CODE=

BACKUP_DISK="local"
DROPBOX_ACCESS_TOKEN=

#Configuration details for superadmin modules

#Stripe payment details for superadmin module
STRIPE_PUB_KEY=
STRIPE_SECRET_KEY=

#PayPal payment details for superadmin module
PAYPAL_MODE=sandbox

